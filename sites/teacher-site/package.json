{
  "name": "teacher-site",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=4096' vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "node --experimental-strip-types --env-file .env src/lib/server/db/seed.ts",
    "db:setup": "pnpm run db:migrate && pnpm run db:seed",
    "auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
  },
  "dependencies": {
    "@autonomy/actions": "workspace:*",
    "@autonomy/banner": "workspace:*",
    "@autonomy/battery-level": "workspace:*",
    "@autonomy/footer": "workspace:*",
    "@autonomy/four-agreements": "workspace:*",
    "@autonomy/header": "workspace:*",
    "@autonomy/hero": "workspace:*",
    "@autonomy/horizontal-scroll": "workspace:*",
    "@autonomy/logo": "workspace:*",
    "@autonomy/nav": "workspace:*",
    "@autonomy/pill": "workspace:*",
    "@autonomy/reading-time": "workspace:*",
    "@autonomy/revealing_image": "workspace:*",
    "@autonomy/scroll-to-top": "workspace:*",
    "@autonomy/style": "workspace:*",
    "@autonomy/theme-toggle": "workspace:*",
    "@autonomy/twelve-steps": "workspace:*",
    "@better-auth/infra": "catalog:",
    "@lucide/svelte": "catalog:",
    "canvas-confetti": "catalog:",
    "svelte-french-toast": "^1.2.0"
  },
  "devDependencies": {
    "@better-auth/cli": "~1.4.21",
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@libsql/client": "^0.17.3",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/enhanced-img": "catalog:",
    "@sveltejs/kit": "^2.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/canvas-confetti": "catalog:",
    "@types/node": "^22.19.19",
    "@typescript/native-preview": "catalog:",
    "better-auth": "~1.4.22",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.18.0",
    "globals": "^17.6.0",
    "mdsvex": "^0.12.7",
    "node-addon-api": "catalog:",
    "node-gyp": "^11.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.2",
    "stylelint": "catalog:",
    "stylelint-config-standard": "catalog:",
    "svelte": "^5.55.10",
    "svelte-check": "^4.4.8",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vite-imagetools": "^10.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
