# Drizzle - point at the same DB used by the teacher-site (e.g. shared Turso URL)
DATABASE_URL=""
DATABASE_AUTH_TOKEN=""

# Origin of THIS site (student-site), e.g. http://localhost:5173 in dev
ORIGIN=""
PUBLIC_ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Google OAuth (student-site has its own OAuth app/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Sentry — server-side runtime
SENTRY_DSN=""
SENTRY_ENVIRONMENT=""
SENTRY_RELEASE=""

# Sentry — client-side runtime (exposed to the browser via Vite)
PUBLIC_SENTRY_DSN=""

# Sentry — build-time source map upload (do NOT commit real values)
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
