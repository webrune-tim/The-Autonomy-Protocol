{
  "name": "the-autonomy-protocol",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ready": "vp check && vp run -r test && vp run -r build",
    "dev:teacher-site": "vp run teacher-site#dev",
    "dev:student-site": "vp run student-site#dev",
    "prepare": "vp config"
  },
  "dependencies": {
    "@img/sharp-darwin-arm64": "catalog:",
    "@img/sharp-libvips-darwin-arm64": "catalog:",
    "node-addon-api": "^8.7.0",
    "node-gyp": "^11.5.0",
    "sharp": "catalog:"
  },
  "devDependencies": {
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "@parcel/watcher"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "svelte": "5"
      },
      "ignoreMissing": [
        "svelte"
      ]
    },
    "supportedArchitectures": {
      "os": [
        "darwin",
        "linux"
      ],
      "cpu": [
        "arm64",
        "x64"
      ]
    }
  }
}
